{
  "name": "discord-agents",
  "productName": "Discord Agents",
  "version": "0.11.0",
  "description": "Control panel for Discord Agents - persistent AI minds on Discord",
  "main": "main.js",
  "author": "Charles Belanger",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "bundle": "node build-bundle.js",
    "dist": "electron-builder --win nsis",
    "release": "electron-builder --win nsis --publish always",
    "test": "node test/updater.test.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "dev.discordagents.supervisor",
    "afterPack": "./after-pack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "CharlesTheFool",
        "repo": "discord-agents"
      }
    ],
    "files": [
      "main.js",
      "updater.js",
      "placeholder.html",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "bundle/runtime",
        "to": "runtime"
      },
      {
        "from": "bundle/framework",
        "to": "framework"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
