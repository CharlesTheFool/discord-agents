# Alpha Bot Configuration Template (v0.6.0 Simplified)
# Copy to deployment/bots/alpha.yaml or bots/alpha.yaml and customize
#
# This config has been simplified from ~150 options to ~30.
# Many implementation details are now internal defaults.
# Style/engagement behavior is controlled via personality prompt, not config.

# ============================================================
# BOT IDENTITY
# ============================================================
bot_id: alpha
name: "Claude (Alpha)"
description: "Helpful, thoughtful Discord bot powered by Claude"

# ============================================================
# DISCORD CONNECTION
# ============================================================
discord:
  # Environment variable containing your Discord bot token
  token_env_var: "ALPHA_BOT_TOKEN"

  # Discord server IDs where this bot operates
  # Right-click server > Copy ID (requires Developer Mode)
  servers:
    - "YOUR_SERVER_ID_HERE"

  # Bot activity status shown in Discord
  status: "Helpful AI assistant"

  # Default server timezone (IANA format)
  timezone: "UTC"

  # Allow bot to respond to other bots
  allow_bot_interactions: false

  # Historical message backfill
  backfill_enabled: true
  backfill_days: 30  # Set to 0 for unlimited

# ============================================================
# PERSONALITY
# ============================================================
# Define your bot's character AND behavior style in the prompt.
# Engagement style, formality, emoji usage, formatting - all go here.
personality:
  base_prompt: |
    You are a helpful, knowledgeable AI assistant in a Discord server.
    You provide clear, accurate information and engage naturally in conversations.

    ## Engagement Style
    Only respond when directly addressed or when you have genuinely useful input.
    Don't jump into conversations just to participate or acknowledge.
    If others are handling the discussion well, stay quiet.

    ## Communication Style
    - Keep responses concise and conversational
    - Use minimal formatting (no headers, bullet points sparingly)
    - Match the energy and tone of the conversation
    - Be friendly but not overly enthusiastic

  # Reactions are programmatic (not part of message generation)
  reaction_usage: "moderate"  # never | rare | moderate | frequent

# ============================================================
# RESPONSE BEHAVIOR
# ============================================================
reactive:
  enabled: true
  always_respond_to_mentions: true  # Guaranteed response to @mentions
  rate_limit: "moderate"            # strict | moderate | permissive | unlimited
  check_interval_seconds: 60        # How often pending messages are scanned

# ============================================================
# AUTONOMOUS BEHAVIOR
# ============================================================
agentic:
  enabled: true
  check_interval_hours: 1.0

  # Follow-up system - track events and check in later
  followups:
    enabled: true

  # Proactive engagement - initiate conversations in idle channels
  proactive:
    enabled: false
    intensity: "moderate"          # gentle | moderate | active
    quiet_hours: [0, 1, 2, 3, 4, 5, 6]  # Local (host clock) hours to stay quiet
    allowed_channels: []           # Empty = all channels

# ============================================================
# AI MODEL
# ============================================================
api:
  model: "claude-sonnet-4-6"
  max_tokens: 16000

  # Context management
  context_messages: 30        # Messages to remember (rolling window)
  context_tokens: 80000       # Session token threshold: episodize + reseed past this (from response.usage)

  # Effort - main cost/depth dial: low | medium | high | max
  # Omit for API default (high). Chat bots usually want low/medium.
  effort: "medium"

  # Adaptive thinking - model decides when and how much to think
  thinking:
    enabled: true

  # Web Search - all or nothing (no rate limiting)
  web_search:
    enabled: true

# ============================================================
# INTEGRATIONS
# ============================================================

# MCP (Model Context Protocol) - external data sources
mcp:
  enabled: false

# Skills - modular instruction packages (always enabled)
# Code execution is automatically enabled with skills
skills:
  include_anthropic_skills: true  # xlsx, pptx, docx, pdf
  default_skills: ["pdf"]         # Loaded initially; the bot can swap via request_skill

# Unified attachment system (images, documents, spreadsheets, code files)
attachments:
  enabled: false
  backfill_enabled: true
  backfill_days: 30
  # Bot file repository (v0.6.1): persistent per-server local drive at
  # repository/{bot_id}/{server_id}/ - drop files in by hand, the bot sees them.
  repository:
    enabled: true

# ============================================================
# DATA ISOLATION (Multi-tenant)
# ============================================================
# Simple mode selection replaces 6 granular settings
data_isolation: "off"  # off | server | channel

# ============================================================
# LOGGING
# ============================================================
logging:
  level: "INFO"
  file: "logs/{bot_id}.log"
